{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Desktop permissions for the local DualCode backend sidecar",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{"name": "binaries/dualcode-backend", "sidecar": true}]
    }
  ]
}
