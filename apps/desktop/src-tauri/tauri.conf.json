{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DualCode Workbench",
  "version": "0.1.6",
  "identifier": "dev.dualcode.workbench",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{"title": "DualCode Workbench", "width": 1440, "height": 900, "minWidth": 1100, "minHeight": 700, "decorations": false, "shadow": true, "theme": "Dark"}],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:8876 http://127.0.0.1:8876; img-src 'self' asset: data: http://127.0.0.1:8876; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "externalBin": ["binaries/dualcode-backend"],
    "resources": {"binaries/dualcode-backend-runtime/": "dualcode-backend-runtime/"}
  }
}
